# Gemini access. Leave empty when working against mocks.
GEMINI_API_KEY=

# Mock-first is the dev default: 1 = no real API calls, no spend.
# Real generations cost ~$1.00 each. Only set to 0 for deliberate, budgeted runs.
MOCK_OMNI=1

# Vercel Blob write access for generated films and scene images.
BLOB_READ_WRITE_TOKEN=

# Global live-film generations allowed per day.
DAILY_FILM_CAP=

# Live-film generations allowed per visitor per day.
VISITOR_FILM_CAP=

# Generated scene collections allowed per day.
DAILY_SCENE_CAP=

# Generated scene collections allowed per visitor per day.
VISITOR_SCENE_CAP=

# Signs the scene photo ids that decide which URLs the film pipeline will fetch.
# Falls back to BLOB_READ_WRITE_TOKEN; if neither is set, real scene generation
# is refused rather than signing with a public constant.
SCENE_DESCRIPTOR_SECRET=

# Optional private presentation unlock. Never put a real value in this file.
DEMO_UNLOCK=
