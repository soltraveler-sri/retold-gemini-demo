# Gemini access. Leave empty when working against mocks.
GEMINI_API_KEY=

# Mock-first is the dev default: 1 = no real API calls, no spend.
# Real generations cost ~$1.00 each. Only set to 0 for deliberate, budgeted runs.
MOCK_OMNI=1

# Vercel Blob write access for generated films and scene images.
BLOB_READ_WRITE_TOKEN=

# Global live-film generations allowed per day.
DAILY_FILM_CAP=

# Live-film generations allowed per visitor per day.
VISITOR_FILM_CAP=

# Generated scene collections allowed per day.
DAILY_SCENE_CAP=

# Generated scene collections allowed per visitor per day.
VISITOR_SCENE_CAP=

# Signs the scene photo ids that decide which URLs the film pipeline will fetch.
# Falls back to BLOB_READ_WRITE_TOKEN; if neither is set, real scene generation
# is refused rather than signing with a public constant.
SCENE_DESCRIPTOR_SECRET=

# Optional private presentation unlock. Never put a real value in this file.
DEMO_UNLOCK=

# --- Access control (#22) -----------------------------------------------
# Live generation costs real money, so it is bound to an identity. Anonymous
# visitors still get the whole demo: library, walkthrough, and showcase films.

# Signs session cookies and hashes emails. REQUIRED for real generation —
# without it, generation is refused rather than left unmetered. 16+ chars.
AUTH_SECRET=

# Comma-separated allowlists. Removing an address revokes it on the NEXT
# request, even if that person still holds a valid session cookie.
ADMIN_EMAILS=
GUEST_EMAILS=

# Two codes, deliberately. The admin address is public (it is shown in the
# contact nudge), so a single shared code would let any guest sign in as the
# admin and claim the admin budget.
ADMIN_ACCESS_CODE=
GUEST_ACCESS_CODE=

# Budgets in dollars, spent across BOTH film (~$1.00) and scene (~$0.90).
# Admin resets each calendar month; guest credit is one-time and never expires.
ADMIN_MONTHLY_BUDGET_USD=100
GUEST_LIFETIME_BUDGET_USD=15

# Shown on the access nudge's copy-to-clipboard button.
CONTACT_EMAIL=

# Required: caps, budgets, and sign-in throttling all live here. If Redis is
# unreachable, real generation is refused (mock and showcase keep working).
# Vercel's "Upstash for Redis" integration provisions KV_REST_API_URL /
# KV_REST_API_TOKEN instead — the code accepts either pair, so you do not need
# to duplicate them. Set these only if you provisioned via Upstash directly.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
