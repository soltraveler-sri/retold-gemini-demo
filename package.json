{
  "name": "retold-gemini-demo",
  "version": "0.1.0",
  "description": "Select photos in a Google Photos-style library and Gemini Omni turns them into a short generative film — a product-thesis demo.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "collections:seed": "tsx scripts/seed-collections.ts",
    "fixtures:make": "tsx scripts/make-fixtures.ts",
    "showcase:generate": "tsx scripts/generate-showcase.ts",
    "smoke:omni": "tsx scripts/smoke-omni.ts",
    "test:film": "tsx --test lib/film.test.ts",
    "test:access": "tsx --test lib/access.test.ts",
    "test": "tsx --test lib/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "2.12.0",
    "@vercel/blob": "2.6.1",
    "ffmpeg-static": "5.3.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "sharp": "0.34.5",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  }
}
